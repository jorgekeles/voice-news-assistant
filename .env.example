# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Language preferences (es, en, etc.)
LANGUAGE=es

# TTS Provider: 'gtts' or 'edge-tts'
TTS_PROVIDER=edge-tts

# Voice preferences for edge-tts
# Examples: es-ES-AlvaroNeural, es-MX-JorgeNeural, en-US-AriaNeural
VOICE=es-ES-AlvaroNeural

# Audio settings
AUDIO_DURATION_SECONDS=5
